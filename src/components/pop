import React, { useState, useEffect, useRef } from 'react';

// --- 1. THE SOUND ENGINE (OUTSIDE THE COMPONENT) ---
const playFeedbackTone = (type: 'pop' | 'ding') => {
  const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
  if (!AudioContext) return;

  const ctx = new AudioContext();
  const osc = ctx.createOscillator();
  const gain = ctx.createGain();

  osc.connect(gain);
  gain.connect(ctx.destination);

  if (type === 'pop') {
    // Subtle "Pop" for successful text capture
    osc.frequency.value = 600; 
    osc.type = 'sine';
    gain.gain.setValueAtTime(0.1, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.1);
    osc.start();
    osc.stop(ctx.currentTime + 0.1);
  } else {
    // Louder "Ding" for Commands
    osc.frequency.value = 1000; 
    osc.type = 'triangle';
    gain.gain.setValueAtTime(0.1, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.5);
    osc.start();
    osc.stop(ctx.currentTime + 0.5);
  }
};

// --- 2. THE MAIN COMPONENT ---
export const VoiceRecorder = () => {
  const [isRecording, setIsRecording] = useState(false);
  const [liveText, setLiveText] = useState('');
  const [fullNote, setFullNote] = useState('');
  const recognitionRef = useRef<any>(null);

  useEffect(() => {
    // Setup Speech Recognition
    const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    
    if (!SpeechRecognition) {
      alert("Your browser doesn't support speech recognition. Try Chrome.");
      return;
    }

    const recognition = new SpeechRecognition();
    recognition.continuous = true;      // Keep listening even after pauses
    recognition.interimResults = true;  // Show text while talking
    recognition.lang = 'en-US';

    // --- THE BRAIN: WHAT HAPPENS WHEN YOU TALK ---
    recognition.onresult = (event: any) => {
      const current = event.resultIndex;
      const transcript = event.results[current][0].transcript;
      const isFinal = event.results[current].isFinal;

      // 1. Show live text immediately
      setLiveText(transcript);

      // 2. Only Process when sentence is done
      if (isFinal) {
        console.log("Captured:", transcript);
        
        // Add to the main note
        setFullNote((prev) => prev + " " + transcript);
        
        // PLAY THE POP (Feedback)
        playFeedbackTone('pop');

        // --- CHECK FOR HOT WORDS ---
        const lower = transcript.toLowerCase();

        // COMMAND: PAUSE
        if (lower.includes("pause session") || lower.includes("pause audio")) {
            playFeedbackTone('ding');
            stopRecording();
            alert("Session Paused via Voice Command");
        }

        // COMMAND: FINISH / GENERATE
        if (lower.includes("assessment complete") || lower.includes("generate plan")) {
            playFeedbackTone('ding');
            stopRecording();
            handleGeneratePlan(); // Call your backend function here
        }
        
        // COMMAND: STATUS CHECK
        if (lower.includes("aliyah status")) {
            const synth = window.speechSynthesis;
            synth.speak(new SpeechSynthesisUtterance("System is active and listening."));
        }
      }
    };

    recognition.onerror = (event: any) => {
      console.error("Speech Error:", event.error);
    };

    recognitionRef.current = recognition;

  }, []);

  // --- HELPER FUNCTIONS ---

  const startRecording = () => {
    if (recognitionRef.current) {
      recognitionRef.current.start();
      setIsRecording(true);
      playFeedbackTone('ding'); // Start sound
    }
  };

  const stopRecording = () => {
    if (recognitionRef.current) {
      recognitionRef.current.stop();
      setIsRecording(false);
    }
  };

  const handleGeneratePlan = () => {
    // This is where you trigger the Supabase/OpenAI call
    console.log("GENERATING PLAN WITH NOTE:", fullNote);
    alert("Generating Plan... (Check Console)");
  };

  // --- THE UI ---
  return (
    <div className="p-6 bg-gray-900 text-white rounded-xl shadow-lg border border-gray-700">
      <div className="flex justify-between items-center mb-4">
        <h2 className="text-xl font-bold text-cyan-400">Clinical AI Listener</h2>
        <div className={`w-3 h-3 rounded-full ${isRecording ? 'bg-red-500 animate-pulse' : 'bg-gray-500'}`} />
      </div>

      <div className="mb-6 h-40 overflow-y-auto bg-gray-800 p-4 rounded border border-gray-600 font-mono text-sm">
        <p className="text-gray-400 mb-2">Creating SOAP Note...</p>
        <p>{fullNote}</p>
        <p className="text-cyan-300 italic mt-2">{isRecording ? `listening: "${liveText}"` : ''}</p>
      </div>

      <div className="flex gap-4">
        {!isRecording ? (
          <button 
            onClick={startRecording}
            className="px-6 py-2 bg-cyan-600 hover:bg-cyan-500 rounded font-bold transition-all w-full"
          >
            Start Session
          </button>
        ) : (
          <button 
            onClick={stopRecording}
            className="px-6 py-2 bg-red-600 hover:bg-red-500 rounded font-bold transition-all w-full"
          >
            Stop Listening
          </button>
        )}
      </div>

      <div className="mt-4 text-xs text-gray-500 text-center">
        Say "Assessment Complete" to generate plan.
      </div>
    </div>
  );
};